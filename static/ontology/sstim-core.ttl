#  Date:       2026-04-12
#  Author:     Renato Fabbri <renato@biosyncare.com>
#  License:    CC BY 4.0 <https://creativecommons.org/licenses/by/4.0/>
#
#  OWL 2 DL class hierarchy, object properties, datatype properties, and
#  annotation properties for the Sensory Stimulation domain. Aligns to
#  BFO 2020 (ISO/IEC 21838-2), OBI, IAO, and PROV-O.
#
#  Protected file — do not modify without explicit maintainer instruction.
#  See CLAUDE.md section 3.4.
#
###########################################################################

@prefix sstim:    <https://w3id.org/sstim#> .
@prefix sstim-v:  <https://w3id.org/sstim/vocab#> .
@prefix sstim-sh: <https://w3id.org/sstim/shapes#> .

@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .
@prefix dct:   <http://purl.org/dc/terms/> .
@prefix prov:  <http://www.w3.org/ns/prov#> .
@prefix voaf:  <http://purl.org/vocommons/voaf#> .

@prefix bfo:   <http://purl.obolibrary.org/obo/BFO_> .
@prefix obi:   <http://purl.obolibrary.org/obo/OBI_> .
@prefix iao:   <http://purl.obolibrary.org/obo/IAO_> .
@prefix eco:   <http://purl.obolibrary.org/obo/ECO_> .
@prefix ro:    <http://purl.obolibrary.org/obo/RO_> .


###########################################################################
# Ontology Metadata
###########################################################################

<https://w3id.org/sstim>
    a owl:Ontology, voaf:Vocabulary ;
    owl:versionIRI <https://w3id.org/sstim/0.1.0> ;
    owl:versionInfo "0.1.0" ;
    dct:title "Sensory Stimulation Ontology (SSTIM)"@en,
              "Ontologia della Stimolazione Sensoriale (SSTIM)"@it,
              "Ontologia de Estimulação Sensorial (SSTIM)"@pt,
              "Ontología de Estimulación Sensorial (SSTIM)"@es ;
    dct:description "An OWL 2 ontology formalizing the domain of Sensory Stimulation: the parameter-specified delivery of structured sensory input toward defined physiological, psychological, or cognitive outcomes through identified or proposed neurobiological pathways."@en ;
    dct:creator <https://orcid.org/0000-0001-8602-7064> ;
    dct:created "2026-04-12"^^xsd:date ;
    dct:modified "2026-04-12"^^xsd:date ;
    dct:license <https://creativecommons.org/licenses/by/4.0/> ;
    rdfs:seeAlso <https://github.com/bsc-lab/bsc-lab> ;
    skos:historyNote "v0.1.0 (2026-04): Initial public release. Vocabulary seeded from BSC preset catalog v0.9.1. Term 'Sensory Stimulation' adopted as the established umbrella over the coined term 'Sensory Harnessing'."@en .


###########################################################################
# Part 1 — Core Activity Classes
###########################################################################

sstim:SensoryStimulation a owl:Class ;
    rdfs:subClassOf bfo:0000015 ;
    rdfs:label "Sensory Stimulation"@en,
               "Stimolazione Sensoriale"@it,
               "Estimulação Sensorial"@pt,
               "Estimulación Sensorial"@es ;
    skos:definition "The parameter-specified delivery of structured sensory input, with the aim of inducing a desired change in physiological, psychological, or cognitive state through identified or proposed neurobiological pathways."@en ;
    skos:scopeNote "Covers entrainment-based stimulation (binaural beats, isochronous tones), non-entrainment stimulation (stochastic resonance, attentional anchoring), and autonomic stimulation (paced respiratory entrainment). Does not include passive incidental sensory exposure."@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


sstim:SensoryStimulationIntervention a owl:Class ;
    rdfs:subClassOf sstim:SensoryStimulation ;
    rdfs:subClassOf obi:0000011 ;
    rdfs:label "Sensory Stimulation Intervention"@en,
               "Intervento di Stimolazione Sensoriale"@it,
               "Intervenção de Estimulação Sensorial"@pt,
               "Intervención de Estimulación Sensorial"@es ;
    skos:definition "A specific, designed instance of Sensory Stimulation with defined parameters, target modalities, intended effect, and delivery mechanism. Corresponds to a BSC preset or protocol specification when realized in execution."@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


###########################################################################
# Part 2 — Technique Classes
###########################################################################

sstim:SensoryStimulationTechnique a owl:Class ;
    rdfs:subClassOf obi:0000272 ;
    rdfs:label "Sensory Stimulation Technique"@en,
               "Tecnica di Stimolazione Sensoriale"@it,
               "Técnica de Estimulação Sensorial"@pt,
               "Técnica de Estimulación Sensorial"@es ;
    skos:definition "A repeatable method of Sensory Stimulation characterized by a specific stimulus type, delivery mechanism, and primary proposed neurobiological mechanism. A technique is the type; an intervention is a particular token execution."@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


sstim:EntrainmentBasedTechnique a owl:Class ;
    rdfs:subClassOf sstim:SensoryStimulationTechnique ;
    rdfs:label "Entrainment-Based Technique"@en ;
    skos:definition "A Sensory Stimulation technique whose primary proposed mechanism involves frequency-following responses, phase-locking, or oscillatory coupling between a periodic stimulus and endogenous neural oscillations."@en ;
    skos:example "Binaural beat stimulation, isochronous tone stimulation, photic driving, Symmetry permutation entrainment."@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


sstim:NonEntrainmentTechnique a owl:Class ;
    rdfs:subClassOf sstim:SensoryStimulationTechnique ;
    rdfs:label "Non-Entrainment Technique"@en ;
    skos:definition "A Sensory Stimulation technique whose proposed mechanism does not rely on frequency-following responses. Includes stochastic resonance, autonomic respiratory entrainment, and attentional anchoring via ambient structured sound."@en ;
    skos:example "Calibrated pink noise for stochastic resonance, Martigli breathing oscillation, ambient Symmetry sequences for attentional anchoring."@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .

sstim:EntrainmentBasedTechnique owl:disjointWith sstim:NonEntrainmentTechnique .


###########################################################################
# Part 3 — Preset and Session Classes
###########################################################################

sstim:Preset a owl:Class ;
    rdfs:subClassOf obi:0000272 ;
    rdfs:subClassOf iao:0000030 ;
    rdfs:label "Preset"@en,
               "Preset"@it, "Preset"@pt, "Preset"@es ;
    skos:definition "A reusable, versioned design template specifying the complete audio architecture, target frequency bands, evidence grounding, safety metadata, and multilingual content for a Sensory Stimulation session. A preset is the protocol specification; a session instance is its execution."@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


sstim:SessionSpecification a owl:Class ;
    rdfs:subClassOf iao:0000030 ;
    rdfs:label "Session Specification"@en ;
    skos:definition "A complete, reproducible description of a specific intended execution of a preset, including user-defined overrides of preset defaults. The unit of scientific reproducibility: given a specification and a conforming engine, the acoustic output is fully determined."@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


sstim:SessionInstance a owl:Class ;
    rdfs:subClassOf prov:Activity ;
    rdfs:label "Session Instance"@en ;
    skos:definition "The record of an actual execution of a session specification, including timing, completion status, platform, and optional self-report. Append-only: never modified after creation."@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


sstim:SelfReport a owl:Class ;
    rdfs:subClassOf iao:0000030 ;
    rdfs:label "Self-Report"@en ;
    skos:definition "A post-session self-assessment capturing subjective affect, focus, sleepiness, quality, and optional free text. Collected only with explicit research consent."@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


###########################################################################
# Part 4 — Vocabulary Classification Classes
###########################################################################

sstim:FrequencyBand a owl:Class ;
    rdfs:subClassOf iao:0000030 ;
    rdfs:label "Frequency Band"@en,
               "Banda di Frequenza"@it,
               "Banda de Frequência"@pt,
               "Banda de Frecuencia"@es ;
    skos:definition "An information entity describing a named Hz range used in BSC protocol design for targeting and evidence classification. BSC operational design category — not a medical diagnostic taxonomy or universal EEG ontology."@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


sstim:FrequencyBandGroup a owl:Class ;
    rdfs:subClassOf iao:0000030 ;
    rdfs:label "Frequency Band Group"@en,
               "Gruppo di Bande di Frequenza"@it,
               "Grupo de Bandas de Frequência"@pt,
               "Grupo de Bandas de Frecuencia"@es ;
    skos:definition "A named collection of frequency bands used as a SKOS scheme root or aggregate grouping concept. Not a band with a specific Hz range; used for SKOS hierarchy navigation (skos:narrower* traversal) rather than for range arithmetic."@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


sstim:PresetGroup a owl:Class ;
    rdfs:subClassOf iao:0000030 ;
    rdfs:label "Preset Group"@en ;
    skos:definition "A classification of BSC presets by design character, evidence strength, and use context. Five groups: Heal, Support, Perform, Indulge, Transcend."@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


sstim:EvidenceTierValue a owl:Class ;
    rdfs:subClassOf iao:0000030 ;
    rdfs:label "Evidence Tier Value"@en ;
    skos:definition "A classification of empirical support strength for a specific Sensory Stimulation claim, accounting for study quality, result consistency, modality match, and population match. Six tiers: speculative(1) through established(6)."@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


sstim:EvidenceModalityTag a owl:Class ;
    rdfs:subClassOf iao:0000030 ;
    rdfs:label "Evidence Modality Tag"@en ;
    skos:definition "A tag classifying the stimulation modality in which supporting evidence was gathered. Values: AUD, AV, BREATH, GENERAL, PRECLINICAL, REVIEW. Governs the modality-matching discount when assigning evidence tiers."@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


sstim:SensoryModality a owl:Class ;
    rdfs:subClassOf bfo:0000023 ;
    rdfs:label "Sensory Modality"@en,
               "Modalità Sensoriale"@it,
               "Modalidade Sensorial"@pt,
               "Modalidad Sensorial"@es ;
    skos:definition "A channel of sensory perception through which stimulation is delivered. Values: auditory, visual, somatosensory, interoceptive, vestibular, olfactory."@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


sstim:StimulationMechanism a owl:Class ;
    rdfs:subClassOf bfo:0000015 ;
    rdfs:label "Stimulation Mechanism"@en,
               "Meccanismo di Stimolazione"@it,
               "Mecanismo de Estimulação"@pt,
               "Mecanismo de Estimulación"@es ;
    skos:definition "A proposed neurobiological pathway through which a stimulus produces its intended effect. Mechanisms vary widely in evidence quality; the EvidenceTierValue system provides graded support assessment."@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


sstim:IntendedEffect a owl:Class ;
    rdfs:subClassOf bfo:0000016 ;
    rdfs:label "Intended Effect"@en ;
    skos:definition "A target change in physiological, psychological, or cognitive state that a Sensory Stimulation intervention is designed to facilitate. Reflects design intent, not guaranteed outcome."@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


sstim:StimulusTemporalStructure a owl:Class ;
    rdfs:subClassOf iao:0000030 ;
    rdfs:label "Stimulus Temporal Structure"@en ;
    skos:definition "The temporal organization of a sensory stimulus. Values: periodic, quasi-periodic, aperiodic, adaptive (closed-loop)."@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


###########################################################################
# Part 5 — Evidence and Reference Classes
###########################################################################

sstim:EvidenceClaim a owl:Class ;
    rdfs:subClassOf iao:0000001 ;
    rdfs:label "Evidence Claim"@en ;
    skos:definition "A specific assertion about the effect of a Sensory Stimulation intervention, together with its evidence tier, modality tags, and citation list. Tier assignments are revisable as literature develops."@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


sstim:PublicSafeReference a owl:Class ;
    rdfs:subClassOf iao:0000030 ;
    rdfs:label "Public-Safe Reference"@en ;
    skos:definition "A peer-reviewed publication cleared for citation in BSC user-facing content. Must be cleared in the BSC Reference Agent before use in preset techDesc fields."@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


###########################################################################
# Part 6 — Voice Classes
#
# Each class serves both as the technique (a kind of stimulation method)
# and as the parameter bundle (the datatype properties that specify a
# particular voice in a particular preset). See ADR 0006.
###########################################################################

sstim:Voice a owl:Class ;
    rdfs:subClassOf iao:0000030 ;
    rdfs:label "Voice"@en ;
    skos:definition "An audio layer within a BSC preset, identified by its technique type (Binaural, Martigli, Martigli-Binaural, Symmetry) and carrying the parameters that fully specify that voice. A preset contains 1–6 voices."@en ;
    rdfs:seeAlso <https://github.com/laBioSynCare/laBioSynCare.github.io/blob/main/docs/decisions/0006-one-class-per-technique.md> ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


sstim:BinauralVoice a owl:Class ;
    rdfs:subClassOf sstim:Voice ;
    rdfs:label "Binaural Voice"@en ;
    skos:definition "Two sine tones at slightly different frequencies (fl, fr) presented dichotically to produce a perceived beat at |fr - fl| Hz."@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


sstim:MartigliVoice a owl:Class ;
    rdfs:subClassOf sstim:Voice ;
    rdfs:label "Martigli Voice"@en ;
    skos:definition "A single tone whose frequency oscillates sinusoidally with a breathing arc that decelerates linearly from mp0 to mp1 over md seconds."@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


sstim:MartigliBinauralVoice a owl:Class ;
    rdfs:subClassOf sstim:Voice ;
    rdfs:label "Martigli-Binaural Voice"@en ;
    skos:definition "Binaural beat combined with Martigli breathing oscillation. Both carriers sweep in parallel, maintaining constant beat frequency while timbral register evolves with breathing."@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


sstim:SymmetryVoice a owl:Class ;
    rdfs:subClassOf sstim:Voice ;
    rdfs:label "Symmetry Voice"@en ;
    skos:definition "N notes log-distributed over I octaves, repeated with algebraic group permutation at each cycle boundary, at pulse rate N/d Hz. When I=0, reduces to traditional isochronous tone stimulation."@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .

[] a owl:AllDisjointClasses ;
    owl:members (
        sstim:BinauralVoice
        sstim:MartigliVoice
        sstim:MartigliBinauralVoice
        sstim:SymmetryVoice
    ) .


###########################################################################
# Part 7 — Object Properties
###########################################################################

sstim:targetsFrequencyBand a owl:ObjectProperty ;
    rdfs:domain sstim:Preset ;
    rdfs:range  sstim:FrequencyBand ;
    rdfs:label  "targets frequency band"@en ;
    skos:definition "Links a preset to 1–2 target frequency bands. First entry is the primary band."@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


sstim:hasEvidenceTier a owl:ObjectProperty ;
    rdfs:domain sstim:EvidenceClaim ;
    rdfs:range  sstim:EvidenceTierValue ;
    rdfs:label  "has evidence tier"@en ;
    skos:definition "Links an evidence claim to its strength classification tier, accounting for study quality and modality matching."@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


sstim:hasModalityTag a owl:ObjectProperty ;
    rdfs:domain sstim:EvidenceClaim ;
    rdfs:range  sstim:EvidenceModalityTag ;
    rdfs:label  "has modality tag"@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


sstim:supportsRelation a owl:ObjectProperty ;
    rdfs:domain sstim:EvidenceClaim ;
    rdfs:label  "supports relation"@en ;
    skos:definition "Links an evidence claim to the preset or technique it supports."@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


sstim:citesReference a owl:ObjectProperty ;
    rdfs:domain sstim:EvidenceClaim ;
    rdfs:range  sstim:PublicSafeReference ;
    rdfs:label  "cites reference"@en ;
    skos:definition "Links an evidence claim to a cleared public-safe reference."@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


sstim:proposedMechanism a owl:ObjectProperty ;
    rdfs:domain sstim:SensoryStimulationTechnique ;
    rdfs:range  sstim:StimulationMechanism ;
    rdfs:label  "proposed mechanism"@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


sstim:hasStimulusTemporalStructure a owl:ObjectProperty ;
    rdfs:domain sstim:SensoryStimulationTechnique ;
    rdfs:range  sstim:StimulusTemporalStructure ;
    rdfs:label  "has stimulus temporal structure"@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


sstim:composedOf a owl:ObjectProperty ;
    rdfs:domain sstim:Preset ;
    rdfs:range  sstim:Voice ;
    rdfs:label  "composed of"@en ;
    skos:definition "Links a preset to its 1–6 voice specifications."@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


sstim:inGroup a owl:ObjectProperty, owl:FunctionalProperty ;
    rdfs:domain sstim:Preset ;
    rdfs:range  sstim:PresetGroup ;
    rdfs:label  "in group"@en ;
    skos:definition "Links a preset to its group classification. Each preset belongs to exactly one group."@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


sstim:hasDeliveryModality a owl:ObjectProperty ;
    rdfs:domain sstim:SensoryStimulationIntervention ;
    rdfs:range  sstim:SensoryModality ;
    rdfs:label  "has delivery modality"@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


sstim:hasIntendedEffect a owl:ObjectProperty ;
    rdfs:domain sstim:Preset ;
    rdfs:range  sstim:IntendedEffect ;
    rdfs:label  "has intended effect"@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


sstim:derivedFrom a owl:ObjectProperty ;
    rdfs:domain sstim:Preset ;
    rdfs:range  sstim:Preset ;
    rdfs:label  "derived from"@en ;
    skos:definition "Links a preset to the earlier version it was revised from."@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


sstim:referencesPreset a owl:ObjectProperty, owl:FunctionalProperty ;
    rdfs:domain sstim:SessionSpecification ;
    rdfs:range  sstim:Preset ;
    rdfs:label  "references preset"@en ;
    skos:definition "Links a session specification to the preset it executes."@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


sstim:usesSpecification a owl:ObjectProperty, owl:FunctionalProperty ;
    rdfs:domain sstim:SessionInstance ;
    rdfs:range  sstim:SessionSpecification ;
    rdfs:label  "uses specification"@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


sstim:hasSelfReport a owl:ObjectProperty, owl:FunctionalProperty ;
    rdfs:domain sstim:SessionInstance ;
    rdfs:range  sstim:SelfReport ;
    rdfs:label  "has self-report"@en ;
    skos:definition "Links a session instance to its optional post-session self-assessment. At most one per instance; research consent required."@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


###########################################################################
# Part 8 — Datatype Properties
###########################################################################

sstim:hzMin a owl:DatatypeProperty ;
    rdfs:domain sstim:FrequencyBand ;
    rdfs:range  xsd:decimal ;
    rdfs:label  "Hz minimum"@en ;
    skos:definition "Lower bound (inclusive) of the frequency band in Hz."@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


sstim:hzMax a owl:DatatypeProperty ;
    rdfs:domain sstim:FrequencyBand ;
    rdfs:range  xsd:decimal ;
    rdfs:label  "Hz maximum"@en ;
    skos:definition "Upper bound (inclusive) of the frequency band in Hz."@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


sstim:tierRank a owl:DatatypeProperty ;
    rdfs:domain sstim:EvidenceTierValue ;
    rdfs:range  xsd:integer ;
    rdfs:label  "tier rank"@en ;
    skos:definition "Ordinal rank 1–6 for SPARQL ORDER BY. Speculative=1, Anecdotal=2, Preliminary=3, Moderate=4, Strong=5, Established=6."@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


sstim:platformDeliverable a owl:DatatypeProperty ;
    rdfs:domain sstim:SensoryModality ;
    rdfs:range  xsd:boolean ;
    rdfs:label  "platform deliverable"@en ;
    skos:definition "Whether this modality is deliverable via standard consumer digital platforms without dedicated hardware."@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


sstim:presetVersion a owl:DatatypeProperty ;
    rdfs:domain sstim:Preset ;
    rdfs:range  xsd:string ;
    rdfs:label  "preset version"@en ;
    skos:definition "Semantic version string (X.Y.Z) of this preset."@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


sstim:hasBreathGuide a owl:DatatypeProperty ;
    rdfs:domain sstim:Preset ;
    rdfs:range  xsd:boolean ;
    rdfs:label  "has breath guide"@en ;
    skos:definition "True iff the preset contains exactly one voice with isOn=true. Governs visual breathing animation and haptic pulse delivery."@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


sstim:durationSeconds a owl:DatatypeProperty ;
    rdfs:domain sstim:SessionSpecification ;
    rdfs:range  xsd:integer ;
    rdfs:label  "duration (seconds)"@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


sstim:breathingPeriodInitial a owl:DatatypeProperty ;
    rdfs:domain sstim:SessionSpecification ;
    rdfs:range  xsd:decimal ;
    rdfs:label  "initial breathing period (s)"@en ;
    skos:definition "User override for mp0. Must be >= 3.0 s for breathing guidance. Absent means use preset default."@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


sstim:breathingPeriodFinal a owl:DatatypeProperty ;
    rdfs:domain sstim:SessionSpecification ;
    rdfs:range  xsd:decimal ;
    rdfs:label  "final breathing period (s)"@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


sstim:breathingTransitionDuration a owl:DatatypeProperty ;
    rdfs:domain sstim:SessionSpecification ;
    rdfs:range  xsd:decimal ;
    rdfs:label  "breathing transition duration (s)"@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


sstim:masterVolume a owl:DatatypeProperty ;
    rdfs:domain sstim:SessionSpecification ;
    rdfs:range  xsd:decimal ;
    rdfs:label  "master volume"@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


sstim:actualDurationSeconds a owl:DatatypeProperty ;
    rdfs:domain sstim:SessionInstance ;
    rdfs:range  xsd:integer ;
    rdfs:label  "actual duration (seconds)"@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


sstim:completionStatus a owl:DatatypeProperty ;
    rdfs:domain sstim:SessionInstance ;
    rdfs:range  xsd:string ;
    rdfs:label  "completion status"@en ;
    skos:definition "Values: 'completed' | 'interrupted' (>30% played) | 'abandoned' (<30% played)."@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


sstim:primaryAffect a owl:DatatypeProperty ;
    rdfs:domain sstim:SelfReport ;
    rdfs:range  xsd:integer ;
    rdfs:label  "primary affect"@en ;
    skos:definition "Post-session affect rating 1–5 (1=very negative, 5=very positive)."@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


sstim:focusRating a owl:DatatypeProperty ;
    rdfs:domain sstim:SelfReport ;
    rdfs:range  xsd:integer ;
    rdfs:label  "focus rating"@en ;
    skos:definition "Post-session attentional focus 1–5 (1=scattered, 5=highly focused)."@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


sstim:sleepiness a owl:DatatypeProperty ;
    rdfs:domain sstim:SelfReport ;
    rdfs:range  xsd:integer ;
    rdfs:label  "sleepiness"@en ;
    skos:definition "Post-session arousal/sleepiness 1–5 (1=alert, 5=very drowsy)."@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


sstim:subjectiveQuality a owl:DatatypeProperty ;
    rdfs:domain sstim:SelfReport ;
    rdfs:range  xsd:integer ;
    rdfs:label  "subjective session quality"@en ;
    skos:definition "Overall session quality rating 1–5 (1=poor, 5=excellent)."@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


sstim:goalAchieved a owl:DatatypeProperty ;
    rdfs:domain sstim:SelfReport ;
    rdfs:range  xsd:boolean ;
    rdfs:label  "goal achieved"@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


sstim:referenceKey a owl:DatatypeProperty ;
    rdfs:domain sstim:PublicSafeReference ;
    rdfs:range  xsd:string ;
    rdfs:label  "reference key"@en ;
    skos:definition "Short uppercase key (e.g. 'INGENDOH_2023') matching citation keys in preset techDesc fields."@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


###########################################################################
# Part 9 — Annotation Properties
###########################################################################

sstim:evidenceNotes a owl:AnnotationProperty ;
    rdfs:label "evidence notes"@en ;
    skos:definition "Internal human-readable note on evidence basis and caveats. Not for user-facing display."@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


sstim:modifiedAt a owl:AnnotationProperty ;
    rdfs:label "modified at"@en ;
    rdfs:range xsd:dateTime ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


sstim:modifiedBy a owl:AnnotationProperty ;
    rdfs:label "modified by"@en ;
    rdfs:isDefinedBy <https://w3id.org/sstim> .


###########################################################################
# End of sstim-core.ttl
###########################################################################
