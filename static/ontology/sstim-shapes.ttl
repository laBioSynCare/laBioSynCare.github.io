###########################################################################
#
#  SSTIM SHACL Shapes  —  sstim-shapes.ttl
#
#  Namespace:  https://w3id.org/sstim/shapes#
#  Version:    0.1.0
#  Date:       2026-04-12
#  Author:     Renato Fabbri <renato@biosyncare.com>
#  License:    CC BY 4.0
#
#  SHACL validation shapes for presets, evidence claims, session
#  specifications, and voice specifications. The pre-commit hook and
#  the export pipeline run these shapes before any preset is committed
#  or exported to dist/presets.json.
#
#  Protected file — do not modify without explicit maintainer instruction.
#
###########################################################################

@prefix sstim:    <https://w3id.org/sstim#> .
@prefix sstim-v:  <https://w3id.org/sstim/vocab#> .
@prefix sstim-sh: <https://w3id.org/sstim/shapes#> .

@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .
@prefix sh:    <http://www.w3.org/ns/shacl#> .
@prefix dct:   <http://purl.org/dc/terms/> .


###########################################################################
# Preset Shape
###########################################################################

sstim-sh:PresetShape a sh:NodeShape ;
    sh:targetClass sstim:Preset ;
    sh:name "Preset"@en ;

    sh:property [
        sh:path rdfs:label ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:message "Preset must have at least one rdfs:label."@en ;
    ] ;

    sh:property [
        sh:path sstim:targetsFrequencyBand ;
        sh:minCount 1 ;
        sh:maxCount 2 ;
        sh:class sstim:FrequencyBand ;
        sh:message "Preset must target 1–2 frequency bands from sstim:FrequencyBand."@en ;
    ] ;

    sh:property [
        sh:path sstim:inGroup ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class sstim:PresetGroup ;
        sh:message "Preset must belong to exactly one group from sstim:PresetGroup."@en ;
    ] ;

    sh:property [
        sh:path sstim:hasBreathGuide ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:boolean ;
        sh:message "Preset must declare hasBreathGuide as a boolean."@en ;
    ] ;

    sh:property [
        sh:path sstim:presetVersion ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:pattern "^\\d+\\.\\d+\\.\\d+$" ;
        sh:message "presetVersion must be a semantic version string X.Y.Z."@en ;
    ] ;

    sh:property [
        sh:path sstim:composedOf ;
        sh:minCount 1 ;
        sh:class sstim:VoiceSpecification ;
        sh:message "Preset must be composed of at least one VoiceSpecification."@en ;
    ] .


###########################################################################
# Voice Specification Shapes
###########################################################################

sstim-sh:VoiceSpecShape a sh:NodeShape ;
    sh:targetClass sstim:VoiceSpecification ;
    sh:name "VoiceSpecification"@en ;
    sh:property [
        sh:path rdf:type ;
        sh:minCount 2 ;
        sh:message "Voice spec must be typed as both sstim:VoiceSpecification and one of the four subtypes."@en ;
    ] .


sstim-sh:BinauralVoiceShape a sh:NodeShape ;
    sh:targetClass sstim:BinauralVoiceSpec ;
    sh:name "BinauralVoiceSpec"@en ;

    sh:property [
        sh:path sstim:carrierFreqLeft ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:datatype xsd:decimal ;
        sh:minExclusive 0 ; sh:maxExclusive 1000 ;
        sh:message "fl must be a positive decimal less than 1000 Hz."@en ;
    ] ;

    sh:property [
        sh:path sstim:carrierFreqRight ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:datatype xsd:decimal ;
        sh:minExclusive 0 ; sh:maxExclusive 1000 ;
        sh:message "fr must be a positive decimal less than 1000 Hz."@en ;
    ] ;

    sh:property [
        sh:path sstim:initialVolume ;
        sh:maxCount 1 ;
        sh:datatype xsd:decimal ;
        sh:minInclusive 0 ; sh:maxExclusive 1 ;
        sh:message "iniVolume must be in [0, 1)."@en ;
    ] .


sstim-sh:SymmetryVoiceShape a sh:NodeShape ;
    sh:targetClass sstim:SymmetryVoiceSpec ;
    sh:name "SymmetryVoiceSpec"@en ;

    sh:property [
        sh:path sstim:baseFrequency ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:datatype xsd:decimal ;
        sh:minInclusive 50 ;
        sh:message "f0 must be >= 50 Hz."@en ;
    ] ;

    sh:property [
        sh:path sstim:noteCount ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:datatype xsd:integer ;
        sh:minInclusive 2 ;
        sh:message "nnotes must be an integer >= 2."@en ;
    ] ;

    sh:property [
        sh:path sstim:octaveSpan ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:datatype xsd:decimal ;
        sh:minInclusive 0 ;
        sh:message "noctaves must be a non-negative decimal."@en ;
    ] ;

    sh:property [
        sh:path sstim:cycleDuration ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:datatype xsd:decimal ;
        sh:minExclusive 0 ;
        sh:message "d must be a positive decimal (seconds)."@en ;
    ] ;

    sh:property [
        sh:path sstim:permutationFunction ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:datatype xsd:integer ;
        sh:minInclusive 0 ; sh:maxInclusive 4 ;
        sh:message "permfunc must be 0, 1, 2, 3, or 4."@en ;
    ] .


###########################################################################
# Evidence Claim Shape
###########################################################################

sstim-sh:EvidenceClaimShape a sh:NodeShape ;
    sh:targetClass sstim:EvidenceClaim ;
    sh:name "EvidenceClaim"@en ;

    sh:property [
        sh:path sstim:hasEvidenceTier ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class sstim:EvidenceTierValue ;
        sh:message "EvidenceClaim must have exactly one evidence tier from sstim:EvidenceTierValue."@en ;
    ] ;

    sh:property [
        sh:path sstim:hasModalityTag ;
        sh:minCount 1 ;
        sh:class sstim:EvidenceModalityTag ;
        sh:message "EvidenceClaim must have at least one modality tag from sstim:EvidenceModalityTag."@en ;
    ] .


###########################################################################
# Session Specification Shape
###########################################################################

sstim-sh:SessionSpecShape a sh:NodeShape ;
    sh:targetClass sstim:SessionSpecification ;
    sh:name "SessionSpecification"@en ;

    sh:property [
        sh:path sstim:referencesPreset ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class sstim:Preset ;
        sh:message "SessionSpecification must reference exactly one Preset."@en ;
    ] ;

    sh:property [
        sh:path sstim:durationSeconds ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:integer ;
        sh:minInclusive 60 ;
        sh:maxInclusive 7200 ;
        sh:message "durationSeconds must be an integer between 60 and 7200."@en ;
    ] ;

    sh:property [
        sh:path sstim:masterVolume ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:decimal ;
        sh:minInclusive 0 ;
        sh:maxInclusive 1 ;
        sh:message "masterVolume must be a decimal in [0, 1]."@en ;
    ] .


###########################################################################
# Session Instance Shape
###########################################################################

sstim-sh:SessionInstanceShape a sh:NodeShape ;
    sh:targetClass sstim:SessionInstance ;
    sh:name "SessionInstance"@en ;

    sh:property [
        sh:path sstim:usesSpecification ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:class sstim:SessionSpecification ;
        sh:message "SessionInstance must use exactly one SessionSpecification."@en ;
    ] ;

    sh:property [
        sh:path sstim:actualDurationSeconds ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:integer ;
        sh:minInclusive 0 ;
        sh:message "actualDurationSeconds must be a non-negative integer."@en ;
    ] ;

    sh:property [
        sh:path sstim:completionStatus ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:in ( "completed" "interrupted" "abandoned" ) ;
        sh:message "completionStatus must be 'completed', 'interrupted', or 'abandoned'."@en ;
    ] .


###########################################################################
# Frequency Band Shape — validate hzMin < hzMax for non-point bands
###########################################################################

sstim-sh:FrequencyBandShape a sh:NodeShape ;
    sh:targetClass sstim:FrequencyBand ;
    sh:name "FrequencyBand"@en ;

    sh:property [
        sh:path sstim:hzMin ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:decimal ;
        sh:minInclusive 0 ;
        sh:message "FrequencyBand must have exactly one hzMin >= 0."@en ;
    ] ;

    sh:property [
        sh:path sstim:hzMax ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:decimal ;
        sh:minInclusive 0 ;
        sh:message "FrequencyBand must have exactly one hzMax >= 0."@en ;
    ] .


###########################################################################
# Public-Safe Reference Shape
###########################################################################

sstim-sh:ReferenceShape a sh:NodeShape ;
    sh:targetClass sstim:PublicSafeReference ;
    sh:name "PublicSafeReference"@en ;

    sh:property [
        sh:path sstim:referenceKey ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:pattern "^[A-Z][A-Z0-9_]+_[0-9]{4}$" ;
        sh:message "referenceKey must match AUTHOR_YEAR pattern (e.g. INGENDOH_2023)."@en ;
    ] ;

    sh:property [
        sh:path dct:title ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:message "PublicSafeReference must have a dct:title."@en ;
    ] .

###########################################################################
# End of sstim-shapes.ttl
###########################################################################
